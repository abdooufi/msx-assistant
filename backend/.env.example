# ─── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/Chatboot

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true

# ─── MSSQL (MSX Website Database) ────────────────────────────────
MSSQL_SERVER=192.168.1.100
MSSQL_PORT=1433
MSSQL_DATABASE=MSM_GEO_Live
MSSQL_USERNAME=sa
MSSQL_PASSWORD=your_password_here

# ─── Ollama ──────────────────────────────────────────────────────
LOCALAI_BASE_URL=http://localhost:11434/v1
LOCALAI_TIMEOUT=120
LOCALAI_MODEL=qwen2.5:7b
LOCALAI_MODEL_FALLBACK=qwen2.5:7b
LOCALAI_MODEL_FAST=qwen2.5:7b
LOCALAI_MODEL_ANALYSIS=qwen2.5:7b

# ─── RAG / ChromaDB ──────────────────────────────────────────────
CHROMA_DB_PATH=./msx_chroma_db
CHROMA_COLLECTION=msx_data
EMBEDDING_MODEL=nomic-embed-text

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
SECRET_KEY=msx-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
